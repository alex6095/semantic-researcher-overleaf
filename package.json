{
  "name": "semantic-researcher-overleaf",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.15.14",
  "icon": "resources/icons/app_icon.png",
  "author": {
    "name": "iamhyc",
    "email": "ychong@petalmail.com"
  },
  "publisher": "alex6095",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/alex6095/semantic-researcher-overleaf#readme",
  "contributors": [
    {
      "name": "iamhyc",
      "email": "ychong@petalmail.com",
      "url": "https://github.com/iamhyc"
    },
    {
      "name": "QianrenLi",
      "email": "liqr2022@mail.sustech.edu.cn",
      "url": "https://github.com/QianrenLi"
    },
    {
      "name": "Mingbo-Lee",
      "url": "https://github.com/Mingbo-Lee"
    },
    {
      "name": "zeyugao",
      "url": "https://github.com/zeyugao"
    },
    {
      "name": "LaureatePoet",
      "url": "https://github.com/LaureatePoet"
    },
    {
      "name": "akretz",
      "url": "https://github.com/akretz"
    },
    {
      "name": "JRodez",
      "url": "https://github.com/JRodez"
    },
    {
      "name": "riccardogibello",
      "url": "https://github.com/riccardogibello"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alex6095/semantic-researcher-overleaf.git"
  },
  "bugs": {
    "url": "https://github.com/alex6095/semantic-researcher-overleaf/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "overleaf",
    "sharelatex",
    "latex",
    "semantic-researcher",
    "local-replica"
  ],
  "activationEvents": [
    "onFileSystem:semantic-researcher-overleaf",
    "workspaceContains:.semantic-researcher-overleaf/settings.json",
    "workspaceContains:.overleaf/settings.json",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "languages": [
      {
        "id": "tex",
        "aliases": [
          "TeX",
          "tex"
        ],
        "extensions": [
          ".sty",
          ".cls",
          ".bbx",
          ".cbx"
        ],
        "configuration": "data/vendor/languages/latex-language-configuration.json"
      },
      {
        "id": "latex",
        "aliases": [
          "LaTeX",
          "latex"
        ],
        "extensions": [
          ".tex",
          ".ltx",
          ".ctx"
        ],
        "configuration": "data/vendor/languages/latex-language-configuration.json"
      },
      {
        "id": "bibtex",
        "aliases": [
          "BibTeX",
          "bibtex"
        ],
        "extensions": [
          ".bib"
        ]
      },
      {
        "id": "cpp_embedded_latex",
        "configuration": "data/vendor/languages/latex-cpp-embedded-language-configuration.json",
        "aliases": []
      },
      {
        "id": "markdown_latex_combined",
        "configuration": "data/vendor/languages/markdown-latex-combined-language-configuration.json",
        "aliases": []
      }
    ],
    "commands": [
      {
        "command": "semantic-researcher-overleaf.remoteFileSystem.refreshLinkedFile",
        "title": "%commands.remoteFileSystem.refreshLinkedFile.title%",
        "icon": "$(refresh)",
        "enablement": "focusedView == 'workbench.explorer.fileView' && (resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activate)",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.remoteFileSystem.createLinkedFile",
        "title": "%commands.remoteFileSystem.createLinkedFile.title%",
        "enablement": "resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activate",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.addServer",
        "title": "%commands.projectManager.addServer.title%",
        "icon": "$(add)",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.removeServer",
        "title": "%commands.projectManager.removeServer.title%",
        "icon": "$(trash)",
        "enablement": "viewItem == server_login || viewItem == server_no_login",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.loginServer",
        "title": "%commands.projectManager.loginServer.title%",
        "icon": "$(log-in)",
        "enablement": "viewItem == server_no_login",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.logoutServer",
        "title": "%commands.projectManager.logoutServer.title%",
        "icon": "$(debug-disconnect)",
        "enablement": "viewItem == server_login",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.refreshServer",
        "title": "%commands.projectManager.refreshServer.title%",
        "icon": "$(refresh)",
        "enablement": "viewItem == server_login",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.newProject",
        "title": "%commands.projectManager.newProject.title%",
        "icon": "$(add)",
        "enablement": "viewItem == server_login",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.copyProject",
        "title": "%commands.projectManager.copyProject.title%",
        "enablement": "viewItem =~ /^(?!archived).*project/",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.renameProject",
        "title": "%commands.projectManager.renameProject.title%",
        "icon": "$(edit)",
        "enablement": "viewItem =~ /^(?!archived).*project/",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.deleteProject",
        "title": "%commands.projectManager.deleteProject.title%",
        "icon": "$(circle-slash)",
        "enablement": "viewItem == trashed_project",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.archiveProject",
        "title": "%commands.projectManager.archiveProject.title%",
        "icon": "$(archive)",
        "enablement": "viewItem =~ /^(?!archived).*project/",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.unarchiveProject",
        "title": "%commands.projectManager.unarchiveProject.title%",
        "icon": "$(reply)",
        "enablement": "viewItem == archived_project",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.trashProject",
        "title": "%commands.projectManager.trashProject.title%",
        "icon": "$(trash)",
        "enablement": "viewItem =~ /^(?!trashed).*project/",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.untrashProject",
        "title": "%commands.projectManager.untrashProject.title%",
        "icon": "$(reply)",
        "enablement": "viewItem == trashed_project",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.createTag",
        "title": "%commands.projectManager.createTag.title%",
        "icon": "$(tag)",
        "enablement": "viewItem == server_login",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.renameTag",
        "title": "%commands.projectManager.renameTag.title%",
        "icon": "$(edit)",
        "enablement": "viewItem == tag",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.deleteTag",
        "title": "%commands.projectManager.deleteTag.title%",
        "icon": "$(close-all)",
        "enablement": "viewItem == tag",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.addProjectToTag",
        "title": "%commands.projectManager.addProjectToTag.title%",
        "icon": "$(tag)",
        "enablement": "viewItem == project",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.removeProjectFromTag",
        "title": "%commands.projectManager.removeProjectFromTag.title%",
        "enablement": "viewItem == project_in_tag",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.openProjectInCurrentWindow",
        "title": "%commands.projectManager.openProjectInCurrentWindow.title%",
        "icon": "$(arrow-right)",
        "enablement": "viewItem == project || viewItem == project_in_tag",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.openProjectInNewWindow",
        "title": "%commands.projectManager.openProjectInNewWindow.title%",
        "icon": "$(empty-window)",
        "enablement": "viewItem == project || viewItem == project_in_tag",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.openProjectLocalReplica",
        "title": "%commands.projectManager.openProjectLocalReplica.title%",
        "icon": "$(file-directory)",
        "enablement": "viewItem == project || viewItem == project_in_tag",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectManager.selectProjectFolderLocalReplica",
        "title": "%commands.projectManager.selectProjectFolderLocalReplica.title%",
        "icon": "$(folder-opened)",
        "enablement": "viewItem == project || viewItem == project_in_tag",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectHistory.refresh",
        "title": "%commands.projectHistory.refresh.title%",
        "icon": "$(refresh)",
        "enablement": "resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activate",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectHistory.clearSelection",
        "title": "%commands.projectHistory.clearSelection.title%",
        "icon": "$(clear-all)",
        "enablement": "view == semantic-researcher-overleaf.projectHistory",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectHistory.createLabel",
        "title": "%commands.projectHistory.createLabel.title%",
        "icon": "$(tag)",
        "enablement": "viewItem =~ /historyItem(Labelled)?/",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectHistory.deleteLabel",
        "title": "%commands.projectHistory.deleteLabel.title%",
        "icon": "$(close-all)",
        "enablement": "viewItem == historyItemLabelled",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectHistory.comparePrevious",
        "title": "%commands.projectHistory.comparePrevious.title%",
        "enablement": "viewItem =~ /historyItem(Labelled)?/",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectHistory.compareCurrent",
        "title": "%commands.projectHistory.compareCurrent.title%",
        "enablement": "viewItem =~ /historyItem(Labelled)?/",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectHistory.compareOthers",
        "title": "%commands.projectHistory.compareOthers.title%",
        "enablement": "viewItem =~ /historyItem(Labelled)?/",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectHistory.downloadProject",
        "title": "%commands.projectHistory.downloadProject.title%",
        "icon": "$(cloud-download)",
        "enablement": "viewItem =~ /historyItem(Labelled)?/",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectHistory.revealHistoryView",
        "title": "%commands.projectHistory.revealHistoryView.title%",
        "enablement": "resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activate",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.projectSCM.configSCM",
        "title": "%commands.projectSCM.configSCM.title%",
        "icon": "$(gear)",
        "enablement": "resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activate",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.compileManager.compile",
        "title": "%commands.compileManager.compile.title%",
        "icon": "$(debug-start)",
        "enablement": "(resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activeReplicaCompileEditor) && resourceExtname == .tex",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.compileManager.viewPdf",
        "title": "%commands.compileManager.viewPdf.title%",
        "icon": "$(open-preview)",
        "enablement": "(resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activeReplicaCompileEditor) && resourceExtname == .tex",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.compileManager.syncCode",
        "title": "%commands.compileManager.syncCode.title%",
        "enablement": "editorTextFocus && (resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activeReplicaCompileEditor) && resourceExtname == .tex",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.compileManager.setCompiler",
        "title": "%commands.compileManager.setCompiler.title%",
        "enablement": "resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activateCompile",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.compileManager.setRootDoc",
        "title": "%commands.compileManager.setRootDoc.title%",
        "enablement": "resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activateCompile",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.collaboration.copyLineRef",
        "title": "%commands.collaboration.copyLineRef.title%",
        "enablement": "editorTextFocus && (resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activeReplicaEditor)",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.collaboration.insertLineRef",
        "title": "%commands.collaboration.insertLineRef.title%",
        "enablement": "editorTextFocus && (resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activeReplicaEditor)",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.collaboration.revealChatView",
        "title": "%commands.collaboration.revealChatView.title%",
        "enablement": "resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activate",
        "category": "%extension.displayName%"
      },
      {
        "command": "semantic-researcher-overleaf.collaboration.jumpToUser",
        "title": "%commands.collaboration.jumpToUser.title%",
        "enablement": "resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activate",
        "category": "%extension.displayName%"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "command": "semantic-researcher-overleaf.compileManager.compile",
        "when": "editorTextFocus && (resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activeReplicaCompileEditor) && resourceExtname == .tex"
      },
      {
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "command": "semantic-researcher-overleaf.compileManager.viewPdf",
        "when": "editorTextFocus && (resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activeReplicaCompileEditor) && resourceExtname == .tex"
      },
      {
        "key": "ctrl+alt+j",
        "mac": "cmd+alt+j",
        "command": "semantic-researcher-overleaf.compileManager.syncCode",
        "when": "editorTextFocus && (resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activeReplicaCompileEditor) && resourceExtname == .tex"
      },
      {
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "command": "semantic-researcher-overleaf.collaboration.copyLineRef",
        "when": "editorTextFocus && (resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activeReplicaEditor)"
      }
    ],
    "configuration": {
      "title": "%extension.displayName%",
      "properties": {
        "semantic-researcher-overleaf.compileOnSave.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "machine",
          "markdownDescription": "%configuration.compileOnSave.enabled.markdownDescription%"
        },
        "semantic-researcher-overleaf.compileOutputFolderName": {
          "type": "string",
          "default": ".output",
          "scope": "machine",
          "pattern": "^[^\\\\/:*?\"<>|]+$",
          "markdownDescription": "%configuration.compileOutputFolderName.markdownDescription%"
        },
        "semantic-researcher-overleaf.pdfViewer.themes": {
          "type": "object",
          "default": {
            "default": {
              "fontColor": "#000000",
              "bgColor": "#FFFFFF"
            },
            "light": {
              "fontColor": "#000000",
              "bgColor": "#F5F5DC"
            },
            "dark": {
              "fontColor": "#FBF0D9",
              "bgColor": "#4B4B4B"
            }
          },
          "patternProperties": {
            "^[a-zA-Z0-9_-]+$": {
              "type": "object",
              "description": "%configuration.pdfViewer.themes.theme.description%",
              "properties": {
                "fontColor": {
                  "type": "string",
                  "format": "color",
                  "description": "%configuration.pdfViewer.themes.fontColor.description%"
                },
                "bgColor": {
                  "type": "string",
                  "format": "color",
                  "description": "%configuration.pdfViewer.themes.backgroundColor.description%"
                }
              }
            }
          },
          "additionalProperties": false,
          "scope": "machine",
          "markdownDescription": "%configuration.pdfViewer.themes.markdownDescription%"
        },
        "semantic-researcher-overleaf.pdfViewer.defaultScrollMode": {
          "type": "string",
          "enum": [
            "vertical",
            "horizontal",
            "wrapped",
            "page"
          ],
          "default": "vertical",
          "scope": "machine",
          "markdownDescription": "%configuration.pdfViewer.defaultScrollMode.markdownDescription%"
        },
        "semantic-researcher-overleaf.pdfViewer.defaultSpreadMode": {
          "type": "string",
          "enum": [
            "none",
            "odd",
            "even"
          ],
          "default": "none",
          "scope": "machine",
          "markdownDescription": "%configuration.pdfViewer.defaultSpreadMode.markdownDescription%"
        },
        "semantic-researcher-overleaf.pdfViewer.citationPreview.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "machine",
          "markdownDescription": "%configuration.pdfViewer.citationPreview.enabled.markdownDescription%"
        },
        "semantic-researcher-overleaf.pdfViewer.citationPreview.maxEntries": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 20,
          "scope": "machine",
          "markdownDescription": "%configuration.pdfViewer.citationPreview.maxEntries.markdownDescription%"
        },
        "semantic-researcher-overleaf.pdfViewer.citationPreview.maxLines": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 20,
          "scope": "machine",
          "markdownDescription": "%configuration.pdfViewer.citationPreview.maxLines.markdownDescription%"
        },
        "semantic-researcher-overleaf.pdfViewer.citationPreview.maxChars": {
          "type": "number",
          "default": 1200,
          "minimum": 120,
          "maximum": 5000,
          "scope": "machine",
          "markdownDescription": "%configuration.pdfViewer.citationPreview.maxChars.markdownDescription%"
        },
        "semantic-researcher-overleaf.invisibleMode.historyRefreshInterval": {
          "type": "number",
          "default": 3,
          "scope": "machine",
          "minimum": 1,
          "maximum": 60,
          "markdownDescription": "%configuration.invisibleMode.historyRefreshInterval.markdownDescription%"
        },
        "semantic-researcher-overleaf.invisibleMode.chatMessageRefreshInterval": {
          "type": "number",
          "default": 3,
          "scope": "machine",
          "minimum": 1,
          "maximum": 60,
          "markdownDescription": "%configuration.invisibleMode.chatMessageRefreshInterval.markdownDescription%"
        },
        "semantic-researcher-overleaf.invisibleMode.inactiveTimeout": {
          "type": "number",
          "default": 180,
          "scope": "machine",
          "minimum": 10,
          "maximum": 3600,
          "markdownDescription": "%configuration.invisibleMode.inactiveTimeout.markdownDescription%"
        },
        "semantic-researcher-overleaf.formatWithLineBreak.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "machine",
          "markdownDescription": "%configuration.formatWithLineBreak.enabled.markdownDescription%"
        },
        "semantic-researcher-overleaf.auth.browserPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "markdownDescription": "%configuration.auth.browserPath.markdownDescription%"
        },
        "semantic-researcher-overleaf.auth.browserLogin.timeoutSeconds": {
          "type": "number",
          "default": 600,
          "scope": "machine",
          "minimum": 30,
          "maximum": 1800,
          "markdownDescription": "%configuration.auth.browserLogin.timeoutSeconds.markdownDescription%"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "semantic-researcher-overleaf",
          "title": "%extension.displayName%",
          "icon": "resources/icons/overleaf_bw.svg"
        }
      ]
    },
    "views": {
      "semantic-researcher-overleaf": [
        {
          "id": "semantic-researcher-overleaf.projectManager",
          "name": "%views.semantic-researcher-overleaf.projectManager.name%"
        }
      ],
      "explorer": [
        {
          "id": "semantic-researcher-overleaf.projectHistory",
          "icon": "$(history)",
          "name": "%views.explorer.semantic-researcher-overleaf.projectHistory%",
          "contextualTitle": "%views.explorer.semantic-researcher-overleaf.contextualTitle%",
          "when": "resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activate"
        },
        {
          "type": "webview",
          "id": "semantic-researcher-overleaf.chatWebview",
          "icon": "$(feedback)",
          "name": "%views.explorer.semantic-researcher-overleaf.chatWebview.name%",
          "contextualTitle": "%views.explorer.semantic-researcher-overleaf.chatWebview.contextualTitle%",
          "when": "resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activate"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "semantic-researcher-overleaf.remoteFileSystem.refreshLinkedFile",
          "when": "(resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activate) && !explorerResourceIsFolder"
        },
        {
          "command": "semantic-researcher-overleaf.remoteFileSystem.createLinkedFile",
          "when": "(resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activate) && explorerResourceIsFolder"
        }
      ],
      "editor/context": [
        {
          "command": "semantic-researcher-overleaf.collaboration.copyLineRef",
          "when": "resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activeReplicaEditor"
        },
        {
          "command": "semantic-researcher-overleaf.collaboration.insertLineRef",
          "when": "resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activeReplicaEditor"
        }
      ],
      "view/title": [
        {
          "command": "semantic-researcher-overleaf.projectManager.addServer",
          "when": "view == semantic-researcher-overleaf.projectManager",
          "group": "navigation"
        },
        {
          "command": "semantic-researcher-overleaf.projectSCM.configSCM",
          "when": "view == semantic-researcher-overleaf.projectHistory",
          "group": "navigation@1"
        },
        {
          "command": "semantic-researcher-overleaf.projectHistory.refresh",
          "when": "view == semantic-researcher-overleaf.projectHistory",
          "group": "navigation@2"
        },
        {
          "command": "semantic-researcher-overleaf.projectHistory.clearSelection",
          "when": "view == semantic-researcher-overleaf.projectHistory",
          "group": "navigation@3"
        }
      ],
      "editor/title": [
        {
          "command": "semantic-researcher-overleaf.compileManager.compile",
          "when": "(resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activeReplicaCompileEditor) && resourceExtname == .tex",
          "group": "navigation@1"
        },
        {
          "command": "semantic-researcher-overleaf.compileManager.viewPdf",
          "when": "(resourceScheme == semantic-researcher-overleaf || semantic-researcher-overleaf.activeReplicaCompileEditor) && resourceExtname == .tex",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "semantic-researcher-overleaf.projectManager.loginServer",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == server_no_login",
          "group": "inline"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.newProject",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == server_login",
          "group": "inline@1"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.refreshServer",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == server_login",
          "group": "inline@2"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.logoutServer",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == server_login",
          "group": "inline@3"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.removeServer",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == server_login || viewItem == server_no_login"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.copyProject",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem =~ /^(?!archived).*project/",
          "group": "1_editActions"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.renameProject",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem =~ /^(?!archived).*project/",
          "group": "1_editActions"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.deleteProject",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == trashed_project",
          "group": "inline@2"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.archiveProject",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem =~ /^(?!archived).*project/",
          "group": "1_editActions"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.unarchiveProject",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == archived_project",
          "group": "inline@1"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.trashProject",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem =~ /^(?!trashed).*project/",
          "group": "1_editActions"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.untrashProject",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == trashed_project",
          "group": "inline@1"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.createTag",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == server_login"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.renameTag",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == tag",
          "group": "inline@1"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.deleteTag",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == tag",
          "group": "inline@2"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.addProjectToTag",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == project",
          "group": "1_editActions"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.removeProjectFromTag",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == project_in_tag",
          "group": "1_editActions"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.openProjectInCurrentWindow",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == project || viewItem == project_in_tag",
          "group": "inline@3"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.openProjectInNewWindow",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == project || viewItem == project_in_tag",
          "group": "inline@4"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.selectProjectFolderLocalReplica",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == project || viewItem == project_in_tag",
          "group": "inline@5"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.openProjectInCurrentWindow",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == project || viewItem == project_in_tag",
          "group": "1_openActions@1"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.openProjectInNewWindow",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == project || viewItem == project_in_tag",
          "group": "1_openActions@2"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.openProjectLocalReplica",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == project || viewItem == project_in_tag",
          "group": "1_openActions@3"
        },
        {
          "command": "semantic-researcher-overleaf.projectManager.selectProjectFolderLocalReplica",
          "when": "view == semantic-researcher-overleaf.projectManager && viewItem == project || viewItem == project_in_tag",
          "group": "1_openActions@4"
        },
        {
          "command": "semantic-researcher-overleaf.projectHistory.createLabel",
          "when": "view == semantic-researcher-overleaf.projectHistory && viewItem =~ /historyItem(Labelled)?/",
          "group": "1_labelActions@0"
        },
        {
          "command": "semantic-researcher-overleaf.projectHistory.deleteLabel",
          "when": "view == semantic-researcher-overleaf.projectHistory && viewItem == historyItemLabelled",
          "group": "1_labelActions@1"
        },
        {
          "command": "semantic-researcher-overleaf.projectHistory.comparePrevious",
          "when": "view == semantic-researcher-overleaf.projectHistory && viewItem =~ /historyItem(Labelled)?/",
          "group": "2_scmActions@1"
        },
        {
          "command": "semantic-researcher-overleaf.projectHistory.compareCurrent",
          "when": "view == semantic-researcher-overleaf.projectHistory && viewItem =~ /historyItem(Labelled)?/",
          "group": "2_scmActions@0"
        },
        {
          "command": "semantic-researcher-overleaf.projectHistory.compareOthers",
          "when": "view == semantic-researcher-overleaf.projectHistory && viewItem =~ /historyItem(Labelled)?/",
          "group": "2_scmActions@2"
        },
        {
          "command": "semantic-researcher-overleaf.projectHistory.downloadProject",
          "when": "view == semantic-researcher-overleaf.projectHistory && viewItem =~ /historyItem(Labelled)?/",
          "group": "z_downloadAction"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "semantic-researcher-overleaf.pdfViewer",
        "displayName": "%customEditors.semantic-researcher-overleaf.pdfViewer.displayName%",
        "selector": [
          {
            "filenamePattern": "semantic-researcher-overleaf:/**/{*.pdf, .PDF}"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "download-pdfjs": "download -o views/pdf-viewer/vendor -e https://github.com/mozilla/pdf.js/releases/download/v3.10.111/pdfjs-3.10.111-dist.zip && cd views/pdf-viewer/vendor && patch -p1 < pdfjs-3.10.111-dist.patch",
    "download-latex-basics": "download -o data/vendor -s 1 -e https://github.com/jlelong/vscode-latex-basics/archive/refs/tags/v1.5.4.zip",
    "postinstall": "patch-package && npm run download-pdfjs && npm run download-latex-basics",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "npx @vscode/vsce package --no-yarn",
    "compile:remote-pack": "npm --prefix remote-pack run compile",
    "package:remote-pack": "npm --prefix remote-pack run package:vsix",
    "publish:marketplace": "npx @vscode/vsce publish --no-yarn",
    "update-l10n": "npx @vscode/l10n-dev export -o ./l10n ./src",
    "compile": "tsc -p ./ && cd views/chat-view && npm run build",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "prepare": "husky install"
  },
  "dependencies": {
    "@unified-latex/unified-latex-prettier": "^1.8.3",
    "@unified-latex/unified-latex-util-parse": "^1.8.3",
    "@vscode/l10n": "^0.0.18",
    "diff-match-patch": "^1.0.5",
    "form-data": "^4.0.4",
    "fuzzysearch": "^1.0.3",
    "mime-types": "^2.1.35",
    "minimatch": "^9.0.9",
    "node-fetch": "^2.7.0",
    "playwright-core": "1.42.1",
    "prettier": "^3.1.1",
    "socket.io-client": "github:overleaf/socket.io-client#0.9.17-overleaf-5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@types/diff-match-patch": "^1.0.34",
    "@types/fuzzysearch": "^1.0.2",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@types/node-fetch": "^2.6.11",
    "@types/socket.io-client": "^1.4.36",
    "@types/uuid": "^9.0.6",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/l10n-dev": "^0.0.31",
    "@vscode/test-electron": "^2.5.2",
    "download-cli": "^1.1.1",
    "eslint": "^8.41.0",
    "husky": "^8.0.3",
    "mocha": "^10.8.2",
    "patch-package": "^8.0.1",
    "typescript": "^5.1.3"
  },
  "extensionKind": [
    "workspace",
    "ui"
  ]
}
